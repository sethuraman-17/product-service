              "id": "CVE-2026-33814",
              "name": "LanguageSpecificPackageVulnerability",
              "shortDescription": {
                "text": "net/http/internal/http2: golang: golang.org/x/net: Go HTTP/2: Denial of Service via malformed SETTINGS_MAX_FRAME_SIZE frame"
              },
              "fullDescription": {
